# Get your API key from https://accounts.contentcredits.com
# Go to: Publisher Dashboard → My Websites → your registered domain → API Key
NEXT_PUBLIC_CC_API_KEY=pub_your_api_key_here

# Server-only: CC API base URL (never sent to the browser)
# Leave unset to use the default production API.
# CC_API_BASE_URL=https://api.contentcredits.com
