{
  "_managed_by": "../harness/sync.sh — edit the workspace-root copy and re-sync; local overrides go in settings.local.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run type-check)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run build)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.production)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-secrets.sh"
          }
        ]
      }
    ]
  }
}
